@model ItemDetailsViewModel
@{ ViewData["Title"] = $"Item — {Model.Name}"; }

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to Catalog</a>
</div>

<div class="card shadow-sm" style="max-width: 560px;">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">@Model.Name</h5>
        <span class="badge state-badge-@Model.StateName text-white fs-6">@Model.StateName</span>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Category</dt>
            <dd class="col-sm-8">
                <span class="badge bg-secondary">@Model.Category</span>
            </dd>

            <dt class="col-sm-4">Price / day</dt>
            <dd class="col-sm-8">€@Model.PricePerDay.ToString("0.00")</dd>

            <dt class="col-sm-4">State</dt>
            <dd class="col-sm-8">@Model.StateName</dd>

            @if (Model.IsRented && Model.ExpectedReturnDate.HasValue)
            {
                <dt class="col-sm-4">Rented until</dt>
                <dd class="col-sm-8 fw-semibold text-primary">
                    @Model.ExpectedReturnDate.Value.ToLocalTime().ToString("dddd, MMMM dd yyyy")
                </dd>
            }
        </dl>
    </div>

    <div class="card-footer d-flex gap-2">
        @if (Model.IsAvailable)
        {
            <a asp-controller="Rental" asp-action="Rent" asp-route-sku="@Model.Sku"
               class="btn btn-primary">Rent this item</a>
        }
        else if (Model.IsRented)
        {
            <form method="post" asp-controller="Item" asp-action="Return">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sku" value="@Model.Sku" />
                <button type="submit" class="btn btn-warning">Process Return</button>
            </form>
        }
        @if (Model.IsAvailable)
        {
            <form method="post" asp-controller="Item" asp-action="Delete"
                  onsubmit="return confirm('Are you sure you want to delete this item?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sku" value="@Model.Sku" />
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        }
    </div>
</div>

<p class="text-muted mt-4" style="font-size: 0.78rem;">
    <strong>[Pattern: Proxy]</strong> The first request for this SKU is a cache
    <span class="text-danger fw-bold">MISS</span> —
    <code>CachingCatalogRepository</code> delegates to
    <code>EfCoreCatalogRepository</code> and stores the result in
    <code>IMemoryCache</code>.<br>
    Reload within 5 minutes for a cache <span class="text-success fw-bold">HIT</span>
    — no database query is issued.<br><br>
    <span class="text-secondary">Concurrency token (Version): <code>@Model.Version</code></span>
</p>
