@model IEnumerable<CatalogItemViewModel>
@{ ViewData["Title"] = "Catalog"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Rental Catalog</h2>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-success">Add Item</a>
        <a asp-controller="Rental" asp-action="Rent" class="btn btn-primary">New Rental</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">The catalog is empty. Run <code>dotnet ef database update</code> to seed items.</div>
}
else
{
    <div class="card shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Category</th>
                    <th>Name</th>
                    <th class="text-end">Price / day</th>
                    <th>State</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle">
                        <span class="badge bg-secondary">@item.Category</span>
                    </td>
                    <td class="align-middle">
                        <a asp-action="Details" asp-route-sku="@item.Sku"
                           class="text-decoration-none fw-semibold">@item.Name</a>
                    </td>
                    <td class="text-end align-middle">€@item.PricePerDay.ToString("0.00")</td>
                    <td class="align-middle">
                        <span class="badge state-badge-@item.StateName text-white">
                            @item.StateName
                        </span>
                        @if (item.IsRented && item.ExpectedReturnDate.HasValue)
                        {
                            <br />
                            <small class="text-muted">
                                due @item.ExpectedReturnDate.Value.ToLocalTime().ToString("MMM dd, yyyy")
                            </small>
                        }
                    </td>
                    <td class="text-end align-middle">
                        @if (item.IsAvailable)
                        {
                            <a asp-controller="Rental" asp-action="Rent"
                               asp-route-sku="@item.Sku"
                               class="btn btn-sm btn-outline-primary">Rent</a>
                        }
                        else if (item.IsRented)
                        {
                            <form method="post" asp-controller="Item" asp-action="Return"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sku" value="@item.Sku" />
                                <button type="submit" class="btn btn-sm btn-outline-warning">
                                    Return
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="btn btn-sm btn-outline-secondary disabled"
                                  aria-disabled="true">Unavailable</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
